{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A photography project (client) containing multiple photos",
      "type": "object",
      "properties": {
        "category": {
          "type": "string",
          "enum": ["place", "food", "nature"]
        },
        "clientName": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "mainImage": {
          "type": "string",
          "format": "uri"
        },
        "photos": {
          "type": "array",
          "items": { "type": "string" }
        },
        "order": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["category", "clientName", "mainImage", "photos", "order"]
    },
    "GlobalSettings": {
      "title": "Global Settings",
      "description": "Site-wide configuration and content",
      "type": "object",
      "properties": {
        "homeHeadline": { "type": "string" },
        "homeIntro": { "type": "string" },
        "aboutHeadline": { "type": "string" },
        "aboutSub": { "type": "string" },
        "aboutBody": { "type": "string" },
        "heroImages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of all photography projects"
    },
    "/settings/main": {
      "schema": "GlobalSettings",
      "description": "Global constants and text content for the site"
    }
  }
}
